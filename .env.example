# =============================================================================
# Infrastructure .env
# =============================================================================
# Quick start:  cp .env.example .env && ./start.sh
#
# Local dev defaults work out of the box — no edits needed.
# For production (DigitalOcean, etc.), uncomment/change the marked lines.
# =============================================================================

# --- Profiles ---
# "local" enables Mailpit (email catcher). Remove for production.
COMPOSE_PROFILES=local

# --- Traefik ---
TRAEFIK_INSECURE=true
TRAEFIK_DASHBOARD_BIND=0.0.0.0
# Production: bind dashboard to localhost only, set ACME email for Let's Encrypt
# TRAEFIK_DASHBOARD_BIND=127.0.0.1
# ACME_EMAIL=you@example.com

# --- Postgres ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_BIND=0.0.0.0
# Production: use a strong password, bind to localhost
# POSTGRES_PASSWORD=<generate with: openssl rand -base64 32>
# POSTGRES_BIND=127.0.0.1

# --- Redis ---
REDIS_ARGS=--save 60 1
REDIS_HEALTHCHECK_ARGS=
REDIS_BIND=0.0.0.0
# Production: require password, set memory limit, bind to localhost
# REDIS_ARGS=--requirepass <password> --maxmemory 512mb --maxmemory-policy noeviction
# REDIS_HEALTHCHECK_ARGS=-a <password>
# REDIS_BIND=127.0.0.1

# --- Langfuse ---
LANGFUSE_SECRET=local-langfuse-secret-dev-only
LANGFUSE_SALT=local-langfuse-salt-dev-only
LANGFUSE_URL=http://localhost:3030
LANGFUSE_BIND=0.0.0.0
LANGFUSE_TRAEFIK=true
# Production: generate real secrets, bind to localhost
# LANGFUSE_SECRET=<generate with: openssl rand -base64 32>
# LANGFUSE_SALT=<generate with: openssl rand -base64 32>
# LANGFUSE_BIND=127.0.0.1
# LANGFUSE_TRAEFIK=false

# --- Umami ---
UMAMI_SECRET=local-umami-secret-dev-only
UMAMI_BIND=0.0.0.0
UMAMI_TRAEFIK=true
UMAMI_DOMAIN=analytics.local
# Production: real secret, real domain, Let's Encrypt TLS
# UMAMI_SECRET=<generate with: openssl rand -base64 32>
# UMAMI_BIND=127.0.0.1
# UMAMI_DOMAIN=analytics.yourdomain.com
# UMAMI_TLS=true
# UMAMI_CERTRESOLVER=letsencrypt

# --- Volume names (override to preserve existing data on a server) ---
# POSTGRES_VOLUME=my_postgres_data
# REDIS_VOLUME=my_redis_data
# TRAEFIK_VOLUME=my_traefik_letsencrypt
