# =============================================================================
# Infrastructure .env
# =============================================================================
# Copy to .env and fill in values.
# On existing volumes, POSTGRES_USER/POSTGRES_PASSWORD are for documentation
# only — auth is controlled by the data directory, not these env vars.
# =============================================================================

# --- Postgres ---
POSTGRES_USER=caitie_admin_db
POSTGRES_PASSWORD=

# --- Redis ---
REDIS_PASSWORD=

# --- Traefik / Let's Encrypt ---
ACME_EMAIL=jordi@lostriver.llc
TRAEFIK_DASHBOARD_HOST=traefik.caitie.app
TRAEFIK_AUTH=admin:$$apr1$$8EVjn/nj$$GiLUZqcbueTFeD23SuB6x0

# --- Langfuse ---
# Generate secrets: openssl rand -base64 32
LANGFUSE_SECRET=
LANGFUSE_SALT=
LANGFUSE_URL=http://localhost:3030
