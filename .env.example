# =============================================================================
# Infrastructure .env
# =============================================================================
# Quick start:  cp .env.example .env && ./start.sh
#
# Local dev defaults work out of the box — no edits needed.
# For production (DigitalOcean, AWS, etc.), you MUST change:
#   1. POSTGRES_PASSWORD  (default is "postgres" — trivially exploitable)
#   2. LANGFUSE_SECRET, LANGFUSE_SALT  (defaults are marked dev-only)
#   3. UMAMI_SECRET  (same)
#   4. LANGFUSE_INIT_* vars — REMOVE them in prod; do first-user setup manually
#   5. TRAEFIK_INSECURE=false
# Generate secrets with: openssl rand -hex 32  (hex avoids URL-breaking chars)
# =============================================================================

# --- Profiles ---
# "local" enables Mailpit (email catcher). Remove for production.
COMPOSE_PROFILES=local

# --- Traefik ---
TRAEFIK_INSECURE=true
TRAEFIK_DASHBOARD_BIND=127.0.0.1
# HTTP_BIND / HTTPS_BIND: interface for entrypoints. Default 0.0.0.0 (all).
# Set to 127.0.0.1 to hide from the network (useful when TLS isn't set up yet).
# HTTP_BIND=0.0.0.0
# HTTPS_BIND=0.0.0.0
# Production: set ACME email for Let's Encrypt
# ACME_EMAIL=you@example.com

# --- Cloudflare DNS-01 (production, required for sites behind CF proxy) ---
# Scoped API token: Zone:Read + DNS:Edit on the target zone.
# Create at https://dash.cloudflare.com/profile/api-tokens
# CF_DNS_API_TOKEN=<token>

# Trusted reverse-proxy IPs for ForwardedHeaders (real client IP).
# Production (behind Cloudflare): use https://www.cloudflare.com/ips/ — keep updated.
# TRUSTED_PROXY_IPS=173.245.48.0/20,103.21.244.0/22,103.22.200.0/22,103.31.4.0/22,141.101.64.0/18,108.162.192.0/18,190.93.240.0/20,188.114.96.0/20,197.234.240.0/22,198.41.128.0/17,162.158.0.0/15,104.16.0.0/13,104.24.0.0/14,172.64.0.0/13,131.0.72.0/22

# --- Postgres ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_BIND=127.0.0.1
# Production: rotate password (MUST), leave bind on 127.0.0.1 (containers reach
# postgres over the 'infra' docker network — external clients should tunnel).
# POSTGRES_PASSWORD=<generate with: openssl rand -hex 32>

# --- Redis ---
REDIS_ARGS=--save 60 1
REDIS_HEALTHCHECK_ARGS=
REDIS_BIND=127.0.0.1
# Production: require password, set memory limit
# REDIS_ARGS=--requirepass <password> --maxmemory 512mb --maxmemory-policy noeviction
# REDIS_HEALTHCHECK_ARGS=-a <password>

# --- Langfuse ---
LANGFUSE_SECRET=local-langfuse-secret-dev-only
LANGFUSE_SALT=local-langfuse-salt-dev-only
LANGFUSE_URL=https://langfuse.local
LANGFUSE_BIND=127.0.0.1
LANGFUSE_TRAEFIK=true
# Local dev ONLY: seeds a default user/org on first start.
# Production: DELETE these four LANGFUSE_INIT_* lines; create the first user
# manually (otherwise a weak default password is baked into the DB).
LANGFUSE_INIT_ORG_ID=local-dev
LANGFUSE_INIT_ORG_NAME=Local Dev
LANGFUSE_INIT_USER_EMAIL=admin@local.dev
LANGFUSE_INIT_USER_NAME=Admin
LANGFUSE_INIT_USER_PASSWORD=local-dev-only-change-me
# Production: generate real secrets
# LANGFUSE_SECRET=<generate with: openssl rand -hex 32>
# LANGFUSE_SALT=<generate with: openssl rand -hex 32>
# LANGFUSE_TRAEFIK=false

# --- Umami ---
UMAMI_SECRET=local-umami-secret-dev-only
UMAMI_BIND=127.0.0.1
UMAMI_TRAEFIK=true
UMAMI_DOMAIN=analytics.local
# Production: real secret, real domain, Let's Encrypt TLS.
# After first login (admin / umami) — CHANGE THE PASSWORD IMMEDIATELY.
# UMAMI_SECRET=<generate with: openssl rand -hex 32>
# UMAMI_DOMAIN=analytics.yourdomain.com
# UMAMI_TLS=true
# UMAMI_CERTRESOLVER=letsencrypt

# --- Vaultwarden (optional; enable via COMPOSE_PROFILES=vaultwarden) ---
# Production only — gated behind a compose profile so local dev doesn't
# spin it up by accident.
# COMPOSE_PROFILES=vaultwarden              # or "vaultwarden,local" combined
# VAULTWARDEN_TRAEFIK=true
# VAULTWARDEN_HOST=vault.yourdomain.com
# VAULTWARDEN_DOMAIN=https://vault.yourdomain.com
# VAULTWARDEN_CERTRESOLVER=letsencrypt-dns
# VAULTWARDEN_ADMIN_TOKEN=<argon2 hash — bitwarden admin panel; generate with: vaultwarden hash>
# VAULTWARDEN_SIGNUPS=false

# --- Volume names (override to preserve existing data on a server) ---
# POSTGRES_VOLUME=my_postgres_data
# REDIS_VOLUME=my_redis_data
# TRAEFIK_VOLUME=my_traefik_letsencrypt
# VAULTWARDEN_VOLUME=vault_vaultwarden_data  # existing data on a migrated server
